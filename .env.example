# AutoSlide environment template
# Copy this to .env and fill in real values.

JWT_KEY=your-jwt-signing-key
SUPABASE_URL=https://your-supabase-project-url
SUPABASE_KEY=your-supabase-service-role-or-api-key
SUPABASE_DB_CONNECTION=Host=...;Port=...;Database=...;Username=...;Password=...

VIEWER_BASE_URL=http://localhost:3000

# Optional OpenRouter / Ollama AI summarization
OpenRouter__ApiKey=your-openrouter-api-key
OpenRouter__Provider=ollama
OpenRouter__Model=qwen3.5:latest
OpenRouter__OllamaBaseUrl=http://localhost:11434
OpenRouter__OllamaModel=qwen3.5:latest
